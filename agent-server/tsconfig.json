{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleDetection": "force",
    "moduleResolution": "NodeNext",
    "strict": false,
    "noImplicitAny": false,
    // This base config is for editors + `tsc --noEmit` typechecking only. The real
    // build uses the standalone tsconfig.build.json (outDir: dist). noEmit:true here
    // stops a bare `tsc` from littering src/ and tests/ with compiled .js next to each .ts.
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@core/*":     ["src/core/*"],
      "@store/*":    ["src/store/*"],
      "@events/*":   ["src/events/*"],
      "@domain/*":   ["src/domain/*"],
      "@platform/*": ["src/platform/*"],
      "@orch/*":     ["src/orchestration/*"],
      "@entry/*":    ["src/entry/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts", "tests/**/*.tsx"]
}
