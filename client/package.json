{
  "name": "@cortex-agent/client",
  "version": "2026.5.19-2",
  "type": "module",
  "description": "Cortex remote agent client — receives commands from @cortex-agent/server via WebSocket",
  "main": "dist/client.js",
  "bin": {
    "cortex-client": "dist/client.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "npm run build",
    "start": "node dist/client.js",
    "build": "tsc && node scripts/copy-assets.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test --test-force-exit --test-timeout=15000 src/cortex-run-watcher.test.ts tests/client/cortex-run-launch.test.ts"
  },
  "dependencies": {
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "repository": "https://github.com/fangxm233/cortex-agent",
  "keywords": [
    "agent",
    "ai-agent",
    "remote-execution",
    "websocket-client",
    "cortex-agent"
  ]
}
